{
  // Global editor settings (not project-specific)
  "editor.formatOnSave": true,
  "editor.rulers": [100],
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,

  // Markdown, JSON, YAML formatting
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "files.trimTrailingWhitespace": false
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[yaml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  // File exclusions (applies when opening root directly)
  "files.exclude": {
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/.pytest_cache": true,
    "**/.ruff_cache": true
  },

  "search.exclude": {
    "**/node_modules": true,
    "**/.next": true,
    "**/api/.venv": true,
    "**/__pycache__": true,
    "**/.pytest_cache": true,
    "**/.ruff_cache": true
  },

  // Python linting - use Ruff only
  "python.linting.enabled": true,
  "python.linting.flake8Enabled": false,
  "python.linting.ruffEnabled": true,
  "flake8.enabled": false
}
